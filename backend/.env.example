# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>?schema=public
DATABASE_URL=postgresql://taskflow:taskflow_secret@localhost:5432/taskflow?schema=public

# JWT signing secret — must be at least 32 characters, change before deploying
ACCESS_SECRET_TOKEN=change_me_must_be_at_least_32_characters_long

# JWT token lifetime (e.g. 15m, 1h, 24h, 7d)
JWT_EXPIRES_IN=24h

# Express server port
PORT=8000

# Node environment: development | production | test
NODE_ENV=development

# bcrypt cost factor — minimum 12 enforced at startup
BCRYPT_ROUNDS=12
